generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id          String    @id @default(uuid())
  address     String    @unique @db.VarChar(42)
  chainId     Int?                               

  nonce       String?   @db.VarChar(500)         
  nonceExpiry DateTime?                          

  // Profile (optional - user can fill later)
  avatar      String?                            
  bio         String?   @db.VarChar(500)
  website     String?   @db.VarChar(255)
  twitter     String?   @db.VarChar(100)

  createdAt   DateTime  @default(now())
  lastLoginAt DateTime?
  updatedAt   DateTime  @updatedAt

  nfts        Nft[]
  collections Collection[]

  @@map("users")
}

model Collection {
  id              String   @id @default(uuid())
  name            String   @db.VarChar(100)
  symbol          String   @db.VarChar(10)
  description     String?  @db.VarChar(1000)
  image           String?
  verified        Boolean  @default(false)

  ownerAddress    String   @db.VarChar(42)
  owner           User     @relation(fields: [ownerAddress], references: [address])

  nfts            Nft[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([ownerAddress])
  @@map("collections")
}

model Nft {
  id              String      @id @default(uuid())
  tokenId         Int?                             // On-chain token ID (null until minted)
  chainId         Int                              
  contractAddress String      @db.VarChar(42)

  name            String      @db.VarChar(100)
  description     String?     @db.VarChar(1000)
  category        String?
  fileUri         String
  metadataUri     String
  royaltyBps      Int         @default(1000)
  price           Float?                           // Listed price (null = not for sale)
  currency        String?     @db.VarChar(10)      

  collectionId    String?
  collection      Collection? @relation(fields: [collectionId], references: [id])

  creatorAddress  String      @db.VarChar(42)
  creator         User        @relation(fields: [creatorAddress], references: [address])
  ownerAddress    String?     @db.VarChar(42)      // Current owner (null = creator is owner)

  txHash          String?     @db.VarChar(66) 

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([creatorAddress])
  @@index([collectionId])
  @@index([chainId, tokenId])
  @@map("nfts")
}